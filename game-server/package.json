{
  "name": "onerealm-game-server",
  "version": "1.0.0",
  "description": "OneRealm Game Server — Sponsor relay, Tx2 builder, AI hint mock",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "test": "npm run build && node --test dist/*.test.js",
    "test:integration": "npm run build && node --test dist/*.integration.js",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@onelabs/sui": "^1.26.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "google-auth-library": "^10.6.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
